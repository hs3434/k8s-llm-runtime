# --- Stage 1: build Python deps ---
FROM python:3.11-slim AS builder
WORKDIR /build

# uv binary pre-staged in docker/build-context/ (pypi.org isn't reachable
# from build containers in restricted networks).
COPY docker/build-context/uv /usr/local/bin/uv
RUN chmod +x /usr/local/bin/uv && uv --version

COPY pyproject.toml uv.lock* ./
RUN if [ -f uv.lock ]; then \
      uv export --frozen --no-dev --no-emit-project -o requirements.txt; \
    else \
      uv pip compile pyproject.toml -o requirements.txt; \
    fi
# Use a Chinese PyPI mirror for installs since pypi.org often times out
RUN sed -i 's|https://pypi.org/simple|https://pypi.tuna.tsinghua.edu.cn/simple|g' \
    requirements.txt && \
    uv pip install --system --no-cache -r requirements.txt

# --- Stage 2: runtime ---
FROM python:3.11-slim AS runtime

# Helm CLI — tarball pre-staged in docker/build-context/ (mirrors of
# get.helm.sh aren't always reachable from build containers).
COPY docker/build-context/helm-v3.14.0-linux-amd64.tar.gz /tmp/helm.tgz
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates bash && \
    tar -xz -C /tmp -f /tmp/helm.tgz && \
    mv /tmp/linux-amd64/helm /usr/local/bin/helm && \
    rm -rf /tmp/linux-amd64 /tmp/helm.tgz /var/lib/apt/lists/* && \
    helm version --short

# App code
WORKDIR /app
COPY charts/ /chart-source/
COPY src/k8s_llm_runtime/ /app/src/k8s_llm_runtime/
COPY examples/vllm_qwen/server.py /app/server.py

# Python deps from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/src \
    MODEL_CONFIG_PATH=/app/config/models.yaml \
    CHART_PATH=/app/charts/llm-inference

EXPOSE 8080

USER 1000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "2"]
